  //
  // Bilateral enforcement macros
  //
  // _hold macros: press modifier + activate bilateral enforcement layer
  // _tap macros: release all mods, tap home row key, tap parameter key
  //   (used on same-hand keys in bilateral layers to cancel the modifier)
  //

  // Left Pinky
  left_pinky_hold: homey_left_pinky_hold {
    compatible = "zmk,behavior-macro-one-param";
    wait-ms = <0>;
    tap-ms = <0>;
    #binding-cells = <1>;
    bindings
      = <&macro_param_1to1>
      , <&macro_press &kp MACRO_PLACEHOLDER>
      , <&macro_press &mo LAYER_LeftPinky>
      , <&macro_pause_for_release>
      , <&macro_param_1to1>
      , <&macro_release &kp MACRO_PLACEHOLDER>
      , <&macro_release &mo LAYER_LeftPinky>
